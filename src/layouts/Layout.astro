---
import NavBar from '../components/NavBar.vue';
import Footer from '../components/Footer.vue';

interface Props {
	title: string;
	mainClass?: string;
	bodyClass?: string;
}

const { title, mainClass = "flex-1", bodyClass = "min-h-screen" } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Handaru Portfolio" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class={`font-sans text-zinc-100 ${bodyClass} flex flex-col overflow-x-hidden selection:bg-blue/30`}>
		<NavBar client:load />
		<div class={mainClass}>
			<slot />
		</div>
		<Footer client:load />
	</body>
</html>

<style is:global>
	:root {
		--accent: 136, 58, 234;
		--accent-light: 224, 204, 250;
		--accent-dark: 49, 10, 101;
		--accent-gradient: linear-gradient(
			45deg,
			rgb(var(--accent)),
			rgb(var(--accent-light)) 30%,
			white 60%
		);
	}
	html {
		font-family: 'Inter', system-ui, sans-serif;
		background: #050505;
		overflow-y: auto;
		scrollbar-gutter: stable;
	}
    a {
        text-decoration: none;
    }

	/* Scrollbar styling */
	* {
		scrollbar-color: #111 #050505;
		scrollbar-width: thin;
	}

	::-webkit-scrollbar {
		width: 6px;
	}
	::-webkit-scrollbar:horizontal {
		height: 6px;
	}
	::-webkit-scrollbar-track,
	::-webkit-scrollbar-corner {
		background: #050505;
		border-radius: 10px;
	}
	::-webkit-scrollbar-thumb {
		background: #111;
		border-radius: 10px;
	}
	::-webkit-scrollbar-thumb:hover {
		background: #222;
	}
</style>
