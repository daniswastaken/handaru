---
import NavBar from "../components/NavBar.vue";
import Footer from "../components/Footer.vue";
import { ClientRouter } from "astro:transitions";

interface Props {
    title: string;
    mainClass?: string;
    bodyClass?: string;
}

const { title, mainClass = "flex-1", bodyClass = "min-h-screen" } = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="description" content="Handaru Portfolio" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
        <ClientRouter />
        <style is:inline>
            /* Truly global scrollbar hiding */
            html,
            body,
            * {
                scrollbar-width: none !important;
                -ms-overflow-style: none !important;
            }
            ::-webkit-scrollbar {
                display: none !important;
                width: 0 !important;
                height: 0 !important;
            }
        </style>
    </head>
    <body
        transition:animate="none"
        class={`font-sans text-zinc-100 ${bodyClass} flex flex-col overflow-x-hidden selection:bg-blue/30`}
    >
        <NavBar client:load />
        <div class={mainClass}>
            <slot />
        </div>
        <Footer client:load />
    </body>
</html>

<style is:global>
    :root {
        --c-bg: #050505;
        --c-scrollbar: #111;
        --c-scrollbar-hover: #222;
        --accent: 136, 58, 234;
        --accent-light: 224, 204, 250;
        --accent-dark: 49, 10, 101;
        --accent-gradient: linear-gradient(
            45deg,
            rgb(var(--accent)),
            rgb(var(--accent-light)) 30%,
            white 60%
        );
    }

    html {
        font-family: "Inter", system-ui, sans-serif;
        background-color: var(--c-bg);
        overflow-x: hidden;
        overflow-y: scroll;
        scrollbar-width: none; /* Hide for Firefox */
        -ms-overflow-style: none; /* Hide for IE/Edge */
    }

    /* Hide scrollbar for Chrome, Safari and Opera */
    html::-webkit-scrollbar,
    body::-webkit-scrollbar,
    *::-webkit-scrollbar {
        display: none !important;
        width: 0 !important;
        height: 0 !important;
    }

    body {
        width: 100%;
        margin: 0;
        overflow-x: hidden;
    }

    * {
        scrollbar-width: none !important;
    }

    a {
        text-decoration: none;
    }

    ::view-transition-old(root),
    ::view-transition-new(root) {
        animation: none;
        mix-blend-mode: normal;
    }
</style>
