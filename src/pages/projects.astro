---
import Layout from '../layouts/Layout.astro';
import ProjectsComponent from '../components/parser/Projects.vue';
import * as projectsFile from '../contents/projects.md';

const { projects } = projectsFile.frontmatter;
---

<Layout title="Projects - Handaru">
    <main class="max-w-6xl mx-auto px-6 pt-20">
        <h1 class="text-4xl font-bold mb-10 text-center tracking-tight">Projects</h1>
        
        <!-- Pass the projects data to Vue Projects component -->
        <ProjectsComponent projects={projects} client:load />
    </main>
</Layout>
