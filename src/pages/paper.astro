---
import Layout from '../layouts/Layout.astro';
import PapersComponent from '../components/parser/Papers.vue';
import * as papersFile from '../contents/papers.md';

const { papers } = papersFile.frontmatter;
---

<Layout title="Paper - Handaru">
    <main class="max-w-6xl mx-auto px-6 pt-20 pb-20">
        <h1 class="text-4xl font-bold mb-10 text-center tracking-tight">Papers</h1>
        
        <PapersComponent papers={papers} client:only="vue" />
    </main>
</Layout>
