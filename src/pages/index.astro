---
import Layout from '../layouts/Layout.astro';
import AboutComponent from '../components/parser/About.vue';
import { Content, frontmatter } from '../contents/about.md';
---

<Layout title="Handaru">
    <main class="max-w-65ch mx-auto px-6 pt-24 pb-20">
        <AboutComponent 
            mainTitle={frontmatter.mainTitle} 
            backgroundTitle={frontmatter.backgroundTitle} 
            client:load 
        />

        <article class="prose mt-20">
            <Content />
        </article>
    </main>
</Layout>

<style is:global>
    .prose table {
        width: 100%;
        border-collapse: collapse;
        margin: 2rem 0;
    }

    .prose th {
        text-align: left;
        padding: 0.75rem 1rem;
        border-bottom: 2px solid #8882;
        font-weight: 600;
        op: 80;
    }

    .prose td {
        padding: 0.75rem 1rem;
        border-bottom: 1px solid #8881;
        op: 70;
    }

    .prose tr:last-child td {
        border-bottom: none;
    }
</style>

<style is:global>
    /* Base typography */
    .prose {
        color: #BBBBBB; /* Changed from #d4d4d8 */
        font-size: 1.125rem;
        line-height: 1.75;
    }

    /* Special writing styles */
    .prose p {
        margin-bottom: 1.5rem;
    }
    /* Special styles for bold, inline code, underline */
    .prose strong, .prose b, .prose code, .prose u {
        color: #DDDDDD;
    }

    /* Headings */
    .prose h1,
    .prose h2,
    .prose h3,
    .prose h4 {
        color: #fff;
        margin-top: 2.5rem;
        margin-bottom: 1rem;
        font-weight: 600;
        line-height: 1.3;
    }
    .prose h1 {
        font-size: 2.25rem;
    }
    .prose h2 {
        font-size: 1.875rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        padding-bottom: 0.3em;
    }
    .prose h3 {
        font-size: 1.5rem;
    }
    .prose h4 {
        font-size: 1.25rem;
    }

    /* Links */
    .prose a {
        color: #fff; /* Links have different color, they are special */
        text-decoration: underline;
        text-decoration-color: rgba(255, 255, 255, 0.3);
        text-underline-offset: 4px;
        transition: all 0.2s;
    }
    .prose a:hover {
        text-decoration-color: #fff;
    }

    /* Lists */
    .prose ul {
        list-style-type: disc;
        margin-left: 1.5rem;
        margin-bottom: 1.5rem;
    }
    .prose ol {
        list-style-type: decimal;
        margin-left: 1.5rem;
        margin-bottom: 1.5rem;
    }
    .prose li {
        margin-bottom: 0.5rem;
    }

    /* Blockquotes & Misc */
    .prose blockquote {
        border-left: 3px solid rgba(255, 255, 255, 0.2);
        padding-left: 1.25rem;
        margin-left: 0;
        margin-right: 0;
        font-style: italic;
        opacity: 0.8;
    }
    .prose hr {
        border: 0;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
        margin: 3rem auto;
        width: 50px;
    }
    .prose img {
        max-width: 100%;
        height: auto;
        border-radius: 0.375rem;
        margin: 2rem 0;
    }

    /* Code blocks */
    .prose pre {
        padding: 1.25rem 1.5rem;
        border-radius: 0.5rem;
        overflow-x: auto;
        margin: 1.5rem 0;
        background-color: #111 !important;
        border: 1px solid rgba(255, 255, 255, 0.05);
    }

    /* Inline and block code fonts mapped to JetBrains Mono */
    .prose code {
        font-family: "JetBrains Mono", monospace !important;
        font-size: 0.875em;
        background: rgba(120, 120, 120, 0.15);
        padding: 0.2em 0.4em;
        border-radius: 0.25rem;
    }
    .prose pre code {
        background: transparent;
        padding: 0;
        font-size: 0.9em;
    }
</style>